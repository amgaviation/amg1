NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
# Local/preview normally use sk_test_... and whsec_... from a Stripe test-mode webhook.
# Vercel Production must use sk_live_... and the live webhook signing secret.
# Do not commit real values.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: only needed if a client-side Stripe.js integration is added.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

RESEND_API_KEY=
AMG_EMAIL_FROM=
AMG_OPERATIONS_FROM=
AMG_REPLY_TO=
EMAIL_FROM_ADDRESS=
EMAIL_REPLY_TO=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

PORTAL_BOOTSTRAP_ADMIN_EMAIL=
PORTAL_BOOTSTRAP_CLIENT_EMAIL=
PORTAL_BOOTSTRAP_CREW_EMAIL=
PORTAL_BOOTSTRAP_PARTNER_EMAIL=

GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_DEFAULT_BRANCH=main
WEBSITE_EDITOR_ENABLED=true

# Shared secret for the FlightWall LED display bridge (GET /api/flightwall/summary).
# Generate a long random value (e.g. `openssl rand -hex 32`); the device sends it
# as `Authorization: Bearer <token>`. Endpoint is disabled while unset.
FLIGHTWALL_API_TOKEN=your-token-here

# Comma-separated public IPs allowed to open /ops/flightwall (the browser ops
# dashboard) without logging in — e.g. the house network. Anywhere else falls
# back to the normal portal admin login. Home internet IPs are usually
# DYNAMIC and rotate periodically; if the dashboard unexpectedly starts asking
# for login, check whattismyip and update this value in Vercel.
FLIGHTWALL_TRUSTED_IPS=
